---
interface Props {
  title?: string;
}
const { title = 'Jailbreaking Challenge' } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content="Can you convince the AI to reveal its secret?" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@600;700&family=Manrope:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline>
    // Prevent flash of wrong theme
    (function() {
      var saved = localStorage.getItem('theme');
      var theme = saved || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --font-display: 'Chakra Petch', system-ui, sans-serif;
      --font-body: 'Manrope', system-ui, sans-serif;
      --font-mono: 'JetBrains Mono', monospace;

      --text-xs: 0.75rem;
      --text-sm: 0.875rem;
      --text-base: 1rem;
      --text-lg: 1.125rem;
      --text-xl: 1.375rem;
      --text-2xl: 1.75rem;

      --space-1: 4px;
      --space-2: 8px;
      --space-3: 12px;
      --space-4: 16px;
      --space-5: 20px;
      --space-6: 24px;
      --space-8: 32px;
      --space-10: 40px;
      --space-12: 48px;
      --space-16: 64px;

      --radius-sm: 6px;
      --radius-md: 10px;
      --radius-lg: 16px;
      --radius-xl: 20px;
    }

    [data-theme="light"] {
      --bg: oklch(0.98 0.004 100);
      --bg-subtle: oklch(0.96 0.005 100);
      --bg-elevated: oklch(1 0 0);
      --border: oklch(0.88 0.006 100);
      --border-strong: oklch(0.78 0.008 100);
      --text: oklch(0.18 0.01 100);
      --text-muted: oklch(0.52 0.008 100);
      --text-faint: oklch(0.70 0.006 100);
      --accent: oklch(0.42 0.10 175);
      --accent-hover: oklch(0.36 0.10 175);
      --accent-subtle: oklch(0.42 0.10 175 / 0.10);
      --accent-glow: oklch(0.42 0.10 175 / 0.25);
      --success-bg: oklch(0.42 0.10 175 / 0.12);
      --success-border: oklch(0.42 0.10 175 / 0.35);
      --error: oklch(0.55 0.18 25);
    }

    [data-theme="dark"] {
      --bg: oklch(0.14 0.008 100);
      --bg-subtle: oklch(0.18 0.008 100);
      --bg-elevated: oklch(0.20 0.009 100);
      --border: oklch(0.28 0.01 100);
      --border-strong: oklch(0.36 0.012 100);
      --text: oklch(0.93 0.006 100);
      --text-muted: oklch(0.62 0.008 100);
      --text-faint: oklch(0.44 0.006 100);
      --accent: oklch(0.55 0.11 175);
      --accent-hover: oklch(0.62 0.11 175);
      --accent-subtle: oklch(0.55 0.11 175 / 0.15);
      --accent-glow: oklch(0.55 0.11 175 / 0.30);
      --success-bg: oklch(0.55 0.11 175 / 0.14);
      --success-border: oklch(0.55 0.11 175 / 0.40);
      --error: oklch(0.65 0.18 25);
    }

    html, body {
      height: 100%;
    }

    body {
      font-family: var(--font-body);
      font-size: var(--text-base);
      line-height: 1.6;
      color: var(--text);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    a { color: inherit; text-decoration: none; }

    button {
      font-family: var(--font-body);
      cursor: pointer;
      border: none;
      background: none;
    }

    button:focus-visible, a:focus-visible, textarea:focus-visible, input:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    button:focus, a:focus, textarea:focus, input:focus {
      outline: none;
    }

    ::selection {
      background: var(--accent-subtle);
    }

    /* Scrollbar styling */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--text-faint); }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
